PORT=5000
NODE_ENV=development

# MySQL DB configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=georsontech_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Google Workspace SMTP / Nodemailer configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_workspace_email@georsontech.com
EMAIL_PASS=your_google_app_password
EMAIL_FROM=projects@georsontech.com
EMAIL_TO=projects@georsontech.com
HR_EMAIL_TO=hr@georsontech.com

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
